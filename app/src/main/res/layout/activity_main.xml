<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".MainActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Zoom Controls -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/zoom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/controls_container">

        <!-- Zoom Ruler (Hidden by default) -->
        <LinearLayout
            android:id="@+id/zoom_ruler_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/text_current_zoom"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_zoom_shortcut"
                android:gravity="center"
                android:text="1.0x"
                android:textColor="#FFD700"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <FrameLayout
                android:layout_width="240dp"
                android:layout_height="80dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_zoom_ruler" />

                <HorizontalScrollView
                    android:id="@+id/zoom_ruler_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/zoom_ruler_content"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="120dp"
                        android:paddingEnd="120dp">
                        <!-- Added programmatically -->
                    </LinearLayout>
                </HorizontalScrollView>

                <View
                    android:id="@+id/zoom_ruler_indicator"
                    android:layout_width="2dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:background="#FFD700" />
            </FrameLayout>
        </LinearLayout>

        <!-- Zoom Shortcuts -->
        <LinearLayout
            android:id="@+id/zoom_shortcuts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/zoom_05"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_zoom_shortcut"
                android:gravity="center"
                android:text=".5"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/zoom_1"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_zoom_shortcut"
                android:gravity="center"
                android:text="1x"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/zoom_2"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_zoom_shortcut"
                android:gravity="center"
                android:text="2x"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/zoom_5"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_zoom_shortcut"
                android:gravity="center"
                android:text="5x"
                android:textColor="#FFFFFF"
                android:textSize="12sp"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Settings Panel -->
    <LinearLayout
        android:id="@+id/settings_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_settings_panel"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/zoom_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resolution"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.1"/>

        <LinearLayout
            android:id="@+id/resolution_options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Frame Rate"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.1"/>

        <LinearLayout
            android:id="@+id/fps_options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buffer Duration"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.1"/>

        <LinearLayout
            android:id="@+id/buffer_options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
        </LinearLayout>
    </LinearLayout>

    <!-- Main Controls -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/controls_container"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="#4D000000"
        app:layout_constraintBottom_toBottomOf="parent">

        <FrameLayout
            android:id="@+id/btn_save_highlight_container"
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_save_highlight"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_save_highlight"
                android:alpha="0.3"
                android:enabled="false"/>

            <TextView
                android:id="@+id/text_buffer_time"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowRadius="3"
                android:visibility="gone"/>
        </FrameLayout>

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_settings"
            android:padding="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btn_save_highlight_container"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_toggle_buffer"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginStart="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_shutter_buffer"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btn_save_highlight_container"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>